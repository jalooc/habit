{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "meta": {
    "name": "Orbit + Ink",
    "version": "0.4.0",
    "themes": ["light", "dark"],
    "description": "Design tokens for a rotating-habits app. One chromatic accent (coral / sand-coral). Calm, literary, warm."
  },

  "color": {
    "light": {
      "bg":         { "value": "#f5f1ec", "comment": "Bone — page background" },
      "card":       { "value": "#ffffff", "comment": "White — surface (cards, inputs, modals)" },
      "ink":        { "value": "#1a1814", "comment": "Near-black — primary text, primary CTA fill" },
      "inkSoft":    { "value": "#7a766e", "comment": "Secondary text" },
      "inkFaint":   { "value": "#b5b0a6", "comment": "Tertiary text, placeholders, disabled" },
      "accent":     { "value": "#c96442", "comment": "Coral — single chromatic. Active rotation dot, NOW labels, kickers." },
      "accentDim":  { "value": "#e7dccf", "comment": "Coral pastel — outline of inactive dots, dividers." },
      "accentSoft": { "value": "#f4dccf", "comment": "Coral wash — soft background tint (chips, paused card)." },
      "rule":       { "value": "rgba(26,24,20,0.10)", "comment": "Subtle dividing line." }
    },
    "dark": {
      "bg":         { "value": "#1c1d20" },
      "card":       { "value": "#252629" },
      "ink":        { "value": "#ece8e2" },
      "inkSoft":    { "value": "#9a958c" },
      "inkFaint":   { "value": "#5d594f" },
      "accent":     { "value": "#e3a37a", "comment": "Sand-coral — softened for dark surfaces." },
      "accentDim":  { "value": "#3a342d" },
      "accentSoft": { "value": "#2b2723" },
      "rule":       { "value": "rgba(236,232,226,0.10)" }
    }
  },

  "shadow": {
    "light": {
      "card": { "value": "0 1px 2px rgba(26,24,20,0.04), 0 8px 32px rgba(26,24,20,0.08)" },
      "paused": { "value": "0 6px 22px rgba(201,100,66,0.28)" }
    },
    "dark": {
      "card": { "value": "0 1px 2px rgba(0,0,0,0.25), 0 12px 36px rgba(0,0,0,0.4)" },
      "paused": { "value": "0 6px 22px rgba(227,163,122,0.20)" }
    }
  },

  "font": {
    "serif":  { "value": "\"Fraunces\", Georgia, serif", "comment": "Display + body. ital + opsz axes used (variable)." },
    "sans":   { "value": "\"Inter\", system-ui, -apple-system, sans-serif", "comment": "UI text, labels, buttons. Weights 400 / 500 / 600." }
  },

  "type": {
    "h1":           { "font": "serif", "size": 32, "weight": 400, "lineHeight": 1.1, "letterSpacing": -0.4, "comment": "Screen titles" },
    "groupDisplay": { "font": "serif", "size": 22, "weight": 400, "lineHeight": 1.1, "letterSpacing": -0.3 },
    "bodySerif":    { "font": "serif", "size": 16, "weight": 400, "lineHeight": 1.4, "letterSpacing": -0.2, "comment": "Habit names, body copy" },
    "ringCenter":   { "font": "serif", "size": 21, "weight": 400, "lineHeight": 1.2, "letterSpacing": -0.2, "comment": "Up-next text inside the orbit ring" },
    "kicker":       { "font": "sans",  "size": 11, "weight": 500, "lineHeight": 1.0, "letterSpacing": 1.8, "transform": "uppercase", "comment": "Labels above titles, section headers" },
    "sectionLabel": { "font": "sans",  "size": 11, "weight": 500, "lineHeight": 1.0, "letterSpacing": 1.5, "transform": "uppercase" },
    "buttonPrimary":{ "font": "sans",  "size": 12, "weight": 500, "lineHeight": 1.0, "letterSpacing": 1.5, "transform": "uppercase" },
    "buttonSmall":  { "font": "sans",  "size": 11, "weight": 500, "lineHeight": 1.0, "letterSpacing": 1.2 },
    "meta":         { "font": "sans",  "size": 13, "weight": 400, "lineHeight": 1.3 }
  },

  "radius": {
    "hero":   { "value": 28, "comment": "Hero / active rotation cards" },
    "card":   { "value": 22, "comment": "List cards (rotations)" },
    "inner":  { "value": 18, "comment": "Inputs blocks, secondary cards" },
    "subtle": { "value": 16 },
    "input":  { "value": 14, "comment": "Single inputs (name field)" },
    "pill":   { "value": 100, "comment": "Buttons, chips, badges" }
  },

  "density": {
    "compact": { "screenPad": 18, "cardPad": 12, "gap": 8,  "ringBoxPad": "18px 12px 14px" },
    "cozy":    { "screenPad": 22, "cardPad": 16, "gap": 12, "ringBoxPad": "24px 14px 20px", "comment": "Default" },
    "roomy":   { "screenPad": 26, "cardPad": 20, "gap": 16, "ringBoxPad": "32px 18px 26px" }
  },

  "ring": {
    "small":   { "hero": 216, "mini": 56, "miniSmall": 48, "font": 19 },
    "default": { "hero": 244, "mini": 72, "miniSmall": 56, "font": 21 },
    "large":   { "hero": 276, "mini": 88, "miniSmall": 64, "font": 24 },

    "outerRingStroke":     { "value": 1, "comment": "Outer ring stroke width (px)" },
    "inactiveDotRadius":   { "value": 5 },
    "inactiveDotStroke":   { "value": 1.5 },
    "activeDotRadius":     { "value": 12 },
    "activeInnerDotRadius":{ "value": 4, "comment": "White punched-out dot inside the active coral dot" },
    "tickMarkOpacity":     { "value": 0.4 }
  },

  "motion": {
    "ringRotate":   { "duration": 550, "easing": "cubic-bezier(.55,.06,.3,1)", "comment": "Headline rotation when a habit is ticked" },
    "settleHold":   { "duration": 50,  "comment": "Pause after rotation before cursor commits" },
    "uiFast":       { "duration": 200, "easing": "ease" },
    "uiMedium":     { "duration": 250, "easing": "ease" },
    "haloPulse":    { "duration": 2400,"easing": "ease-in-out", "iteration": "infinite" }
  },

  "device": {
    "width":  { "value": 412 },
    "height": { "value": 892 },
    "comment": "Android Pixel-class, design canvas. Mobile-first."
  }
}
